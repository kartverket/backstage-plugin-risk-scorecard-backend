# Duplicate this file and rename to `.env`

ISSUER_URI="http://localhost:7007/api/auth"
RISC_FOLDER_PATH=".security/risc"
FILENAME_PREFIX="risc"
FILENAME_POSTFIX="risc"
INIT_RISC_URL="http://localhost:8085"

GITHUB_APP_ID=... # App-ID of the GitHub app used by users of RiSc-plugin without GitHub account.
GITHUB_APP_PRIVATE_KEY=... # Private key of the GitHub app used by users of RiSc-plugin without GitHub account
GITHUB_APP_INSTALLATION_ID=... # Installation ID of the GitHub app used by users of RiSc-plugin without GitHub account.

# Name and owner of repo storing initial RiScs
INIT_RISC_REPO_OWNER=""
INIT_RISC_REPO_NAME=""

# Configuration of SOPS crypto service (used for encrypting/decrypting riscs)
BACKEND_PUBLIC_KEY=""
SECURITY_PLATFORM_PUBLIC_KEY=""
SECURITY_TEAM_PUBLIC_KEY=""
SOPS_AGE_PRIVATE_KEY=""

# A list of ids of GCP projects that should be used by the system, beyond those that contain "-prod-". This value does
# not need to be set. If not set, no projects with id beyond those that contain "-prod-" will be used.
# The system then fetches at most one key per project id that the current user has access to.
# ADDITIONAL_ALLOWED_GCP_PROJECT_IDS=id-of-project,id-of-other-project,id-of-third-project

### Image build args (optional) ###
# BUILD_IMAGE=
# IMAGE=

# Slack webhook for feedback
SLACK_FEEDBACK_WEBHOOK_URL=

# Enable API docs - Should be false or not present in internet available environments
ENABLE_API_DOCS=true